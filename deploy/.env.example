# =============================================================================
# Agent Platform — Production Environment Variables
# =============================================================================
# Copy to .env and edit. NEVER commit .env to git.
#   cp .env.example .env
#
# Secrets (generate with: python3 -c "import secrets; print(secrets.token_urlsafe(32))")
# =============================================================================

# ----- Required: Authentication -----
# JWT signing key (at least 32 bytes). Change this.
AGENT_PLATFORM_JWT_SECRET=replace-with-a-random-64-char-hex-string

# ----- Required: TaskAgent integration -----
# Shared HMAC secret between Gateway and TaskAgent (both must match)
TASKAGENT_HMAC_SECRET=replace-with-another-random-64-char-hex-string

# ----- Optional: HTTP port -----
HTTP_PORT=80

# ----- Optional: Uploads -----
MAX_UPLOAD_MB=10

# ----- Optional: Logging -----
AGENT_PLATFORM_LOG_LEVEL=INFO

# ----- Required: LLM Configuration -----
# Before starting, create deploy/config/seed.models.json from the example:
#   cp config/seed.models.json.example config/seed.models.json
# Then edit the api_key and model settings.
