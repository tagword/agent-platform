# Generate real secrets with:
#   python -c "import secrets; print(secrets.token_urlsafe(32))"

# Must match between gateway and taskagent
TASKAGENT_HMAC_SECRET=change-me-to-a-real-secret-32-bytes-minimum

# Gateway JWT signing key
AGENT_PLATFORM_JWT_SECRET=change-me-to-another-real-secret-32-bytes

# External port the gateway listens on (host:port)
GATEWAY_PORT=8780
